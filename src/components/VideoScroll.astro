---
// src/components/Header.astro
import { Icon } from "astro-icon/components";
---

<div
    class="relative flex items-center justify-center w-full max-w-5xl mx-auto h-[450px] overflow-hidden px-4 my-8"
>
    <button
        id="previous-btn"
        class="absolute left-0 sm:left-10 z-20 hover:animate-pulse hover:scale-110 transition-transform cursor-pointer bg-black/20 p-2 rounded-full"
    >
        <Icon name="fa6-solid:angle-left" class="size-10 text-teal-400" />
    </button>

    <iframe
        id="vid-0"
        src="https://www.tiktok.com/player/v1/7647510065221602582?autoplay=0"
        class="carousel-video absolute w-[220px] h-[380px] rounded-xl shadow-lg border-none transition-all duration-500 ease-in-out"
        allow="fullscreen"
        loading="lazy"
    >
    </iframe>

    <iframe
        id="vid-1"
        src="https://www.tiktok.com/player/v1/7640552327224511766?autoplay=0"
        class="carousel-video absolute w-[220px] h-[380px] rounded-xl shadow-lg border-none transition-all duration-500 ease-in-out"
        allow="fullscreen"
        loading="lazy"
    >
    </iframe>

    <iframe
        id="vid-2"
        src="https://www.tiktok.com/player/v1/7638966279818202390?autoplay=0"
        class="carousel-video absolute w-[220px] h-[380px] rounded-xl shadow-lg border-none transition-all duration-500 ease-in-out"
        allow="fullscreen"
        loading="lazy"
    >
    </iframe>

    <button
        id="next-btn"
        class="absolute right-0 sm:right-10 z-10 hover:animate-pulse hover:scale-110 transition-transform cursor-pointer bg-black/20 p-2 rounded-full"
    >
        <Icon name="fa6-solid:angle-right" class="size-10 text-teal-400" />
    </button>
</div>

<script>
    // Grab all elements
    const videos = document.querySelectorAll(
        ".carousel-video",
    ) as NodeListOf<HTMLIFrameElement>;
    const nextBtn = document.getElementById("next-btn") as HTMLButtonElement;
    const prevBtn = document.getElementById(
        "previous-btn",
    ) as HTMLButtonElement;

    // We define the 3 layout states as strings of Tailwind classes.
    // Left & Right: Pushed to the side, scaled down, darker, and behind the center video.
    // Center: Normal size, full brightness, brought to the front.
    const states = [
        "-translate-x-28 sm:-translate-x-48 scale-75 brightness-50 z-0 pointer-events-none", // 0: Left State
        "translate-x-0 scale-100 brightness-100 z-10 shadow-2xl pointer-events-auto", // 1: Center State
        "translate-x-28 sm:translate-x-48 scale-75 brightness-50 z-0 pointer-events-none", // 2: Right State
    ];

    // This array maps each video (by index) to a state index above.
    // Start layout: Video 0 is Left, Video 1 is Center, Video 2 is Right.
    let currentPositions = [0, 1, 2];

    function applyPositions() {
        videos.forEach((vid, i) => {
            // First, strip away ALL possible state classes so we have a clean slate
            states.forEach((stateGroup) => {
                const classArray = stateGroup.split(" ");
                vid.classList.remove(...classArray);
            });

            // Now, apply the specific classes for this video's current position
            const currentStateIndex = currentPositions[i];
            const classesToAdd = states[currentStateIndex].split(" ");
            vid.classList.add(...classesToAdd);
        });
    }

    // NEXT BUTTON LOGIC
    if (nextBtn) {
        nextBtn.addEventListener("click", () => {
            // Math magic: Shifts the positions array right
            currentPositions = currentPositions.map((pos) => (pos + 2) % 3);
            applyPositions();
        });
    }

    // PREVIOUS BUTTON LOGIC
    if (prevBtn) {
        prevBtn.addEventListener("click", () => {
            // Math magic: Shifts the positions array left
            currentPositions = currentPositions.map((pos) => (pos + 1) % 3);
            applyPositions();
        });
    }

    // Run this once when the page loads to snap everything into place
    applyPositions();
</script>
